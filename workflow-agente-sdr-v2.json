      "id": "node-webhook",
      "name": "Webhook — Evolution API",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1,
      "position": [0, 400],
      "notes": "Configure este endpoint na Evolution API como webhook de mensagens recebidas."
    },
    {
      "parameters": {
        "jsCode": "const webhook = $input.first().json;\nconst instanceName = webhook.instance || webhook.body?.instance || webhook.instanceName || webhook.body?.instanceName || webhook.data?.instance || webhook.instanceId || '';\nconst fromMe = webhook.fromMe || webhook.key?.fromMe || webhook.data?.key?.fromMe || webhook.body?.data?.key?.fromMe || false;\nif (fromMe === true) return [];\nconst remoteJid = webhook.sender || webhook.remoteJid || webhook.key?.remoteJid || webhook.data?.key?.remoteJid || webhook.body?.data?.key?.remoteJid || '';\nif (remoteJid.includes('@g.us')) return [];\nconst tipoMensagem = webhook.messageType || webhook.data?.messageType || webhook.body?.data?.messageType || 'conversation';\nconst TIPOS_IGNORADOS = ['senderKeyDistributionMessage','protocolMessage','reactionMessage','pollUpdateMessage'];\nif (TIPOS_IGNORADOS.includes(tipoMensagem)) return [];\nconst numero = remoteJid.replace('@s.whatsapp.net', '');\nconst mensagem = webhook.conversation || webhook.text || webhook.body || webhook.data?.message?.conversation || webhook.data?.message?.extendedTextMessage?.text || webhook.body?.data?.message?.conversation || '';\nconst nomeContato = webhook.pushName || webhook.senderName || webhook.data?.pushName || webhook.body?.data?.pushName || 'Lead';\nif (!mensagem) return [];\nreturn [{ json: { numero, mensagem, nomeContato, instanceName, timestamp: new Date().toISOString() } }];"
      },
